  "nodes": [
    {
      "id": "iec_60825_1",
      "type": "standard",
      "label": "IEC 60825-1",
      "properties": {
        "title": "Safety of laser products - Part 1: Equipment classification and requirements",
        "edition": "3.0",
        "year": 2014,
        "status": "Group Safety Publication",
        "wavelength_range": "180 nm to 1 mm",
        "languages": ["English", "French"]
      }
    },
    {
      "id": "accessible_emission",
      "type": "concept",
      "label": "Accessible Emission (AE)",
      "properties": {
        "definition": "Level of radiation determined at a position with specified aperture stops",
        "purpose": "Compared against AEL for classification",
        "unit_power": "Watts",
        "unit_energy": "Joules"
      }
    },
    {
      "id": "ael",
      "type": "concept",
      "label": "Accessible Emission Limit (AEL)",
      "properties": {
        "definition": "Maximum permitted emission for a laser class",
        "purpose": "Classification threshold",
        "applies_to": ["Class 1", "Class 1M", "Class 2", "Class 2M", "Class 3R", "Class 3B", "Class 4"]
      }
    },
    {
      "id": "class_1",
      "type": "laser_class",
      "label": "Class 1",
      "properties": {
        "description": "Safe under reasonably foreseeable conditions",
        "label_requirement": "Optional (mandatory for 4.4 excluded emission)",
        "ocular_hazard": "None under normal use"
      }
    },
    {
      "id": "class_1m",
      "type": "laser_class",
      "label": "Class 1M",
      "properties": {
        "description": "Safe except when viewed with magnifying optics",
        "warning": "Do not view directly with optical instruments",
        "condition": "Safe for naked eye, hazardous with optics"
      }
    },
    {
      "id": "class_2",
      "type": "laser_class",
      "label": "Class 2",
      "properties": {
        "description": "Visible lasers, eye protection by blink reflex",
        "wavelength": "400-700 nm",
        "aversion_response": "Adequate protection"
      }
    },
    {
      "id": "class_3b",
      "type": "laser_class",
      "label": "Class 3B",
      "properties": {
        "description": "Direct beam viewing hazardous",
        "diffuse_reflection": "Normally safe for short exposure",
        "requirements": "Control measures required"
      }
    },
    {
      "id": "class_4",
      "type": "laser_class",
      "label": "Class 4",
      "properties": {
        "description": "High power, fire and diffuse reflection hazard",
        "hazards": ["Eye", "Skin", "Fire", "Diffuse reflection"],
        "requirements": "All hazard control measures required"
      }
    },
    {
      "id": "mpe",
      "type": "concept",
      "label": "Maximum Permissible Exposure (MPE)",
      "properties": {
        "definition": "Level of laser radiation to which a person may be exposed without hazardous effects",
        "location": "Cornea for eye exposure",
        "application": "Safety evaluation and hazard analysis"
      }
    },
    {
      "id": "alpha_max",
      "type": "parameter",
      "label": "Angular Subtense (αmax)",
      "properties": {
        "definition": "Maximum angular subtense of apparent source",
        "determination": "50% of peak radiance",
        "measurement_distance": "200 mm",
        "unit": "mrad"
      }
    },
    {
      "id": "c5_correction",
      "type": "parameter",
      "label": "C5 Correction Factor",
      "properties": {
        "purpose": "Pulse grouping correction factor",
        "application": "Thermal additivity in pulse trains",
        "subclause": "4.3 f) 3)"
      }
    },
    {
      "id": "c6_correction",
      "type": "parameter",
      "label": "C6 Correction Factor",
      "properties": {
        "purpose": "Extended source correction factor",
        "application": "Adjusts AEL for large apparent sources",
        "default_value": 1
      }
    },
    {
      "id": "totp",
      "type": "method",
      "label": "TOTP Method",
      "properties": {
        "full_name": "Total-On-Time Pulse",
        "definition": "Sum of all pulse durations within emission duration or T2",
        "application": "Pulse train analysis",
        "limitation": "Not for strongly varying peak powers"
      }
    },
    {
      "id": "extended_source",
      "type": "concept",
      "label": "Extended Source Analysis",
      "properties": {
        "default_angle": "100 mrad",
        "wavelength_range": "400-1400 nm",
        "evaluation_methods": ["Default (simplified)", "Extended analysis"]
      }
    },
    {
      "id": "arpansa",
      "type": "organization",
      "label": "ARPANSA",
      "properties": {
        "full_name": "Australian Radiation Protection and Nuclear Safety Agency",
