    "pre_event_planning": {
      "title": "Pre-Event Planning Checklist",
      "description": "Critical items to address before scheduling any live entertainment event",
      "items": [
        {
          "id": "PEP-001",
          "category": "Authority Coordination",
          "task": "Confirm event date and time with community public service agencies",
          "priority": "CRITICAL",
          "rationale": "Agencies must verify resource availability before event promotion"
        },
        {
          "id": "PEP-002",
          "category": "Authority Coordination",
          "task": "Identify lead agency and primary contact",
          "priority": "HIGH",
          "rationale": "Prevents confusion in leadership on large events with multiple agencies"
        },
        {
          "id": "PEP-003",
          "category": "Legal",
          "task": "Obtain legal and insurance advice",
          "priority": "CRITICAL",
          "rationale": "Organizers must understand liability for injuries, acts/omissions, and emergency response costs"
        },
        {
          "id": "PEP-004",
          "category": "Permits",
          "task": "Apply for public entertainment permit",
          "priority": "CRITICAL",
          "notes": "Permanent venues may have existing permits with specific conditions"
        },
        {
          "id": "PEP-005",
          "category": "Planning",
          "task": "Conduct initial risk assessment",
          "priority": "HIGH",
          "rationale": "Identifies physical and health hazards before work begins"
        },
        {
          "id": "PEP-006",
          "category": "Planning",
          "task": "Create health and safety policy statement",
          "priority": "HIGH",
          "elements": [
            "Organizational diagrams",
            "Maps and procedures",
            "Roles and responsibilities",
            "Contact information"
          ]
        },
        {
          "id": "PEP-007",
          "category": "Personnel",
          "task": "Appoint Safety Coordinator",
          "priority": "HIGH",
          "responsibilities": [
            "Monitor site safety rules",
            "Select and monitor contractors",
            "Liaison with authorities",
            "Check safety method statements",
            "Verify training and certificates"
          ]
        },
        {
          "id": "PEP-008",
          "category": "Planning",
          "task": "Complete life safety evaluation",
          "priority": "HIGH",
          "assessment_areas": [
            "Nature of events and associated risks",
            "Access and egress evaluation",
            "Structural integrity assessment",
            "Fire safety measures",
            "Emergency communication systems",
            "Emergency response capability"
          ]
        }
      ]
    },
