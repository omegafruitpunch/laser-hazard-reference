      "duration": 12,
      "icon": "layout-grid",
      "activities": [
        "Interactive Safety Planning Timeline",
        "Hazard Assessment Walkthrough",
        "Stakeholder Coordination Scenario"
      ]
    },
    "practice": {
      "title": "Planning Simulator",
      "duration": 6,
      "icon": "play-circle",
      "activities": [
        "Virtual venue assessment",
        "Multi-stakeholder challenge",
        "Decision tree scenarios"
      ]
    },
    "challenge": {
      "title": "Command Ready",
      "duration": 2,
      "icon": "award",
      "activities": [
        "Knowledge verification",
        "Competency badge award"
      ]
    }
  },
  "emergency_elements": {
    "quick_access_checklists": [
      {
        "id": "concept-checklist",
        "title": "Concept Phase Safety",
        "icon": "clipboard-list",
        "priority": "critical",
        "items": [
          { "task": "Confirm event date with public service agencies", "priority": "CRITICAL", "verification": "Written confirmation" },
          { "task": "Identify lead agency and primary contact", "priority": "HIGH" },
          { "task": "Obtain legal and insurance advice", "priority": "CRITICAL" },
          { "task": "Assess community impact", "priority": "HIGH" }
        ]
      },
      {
        "id": "loadin-checklist",
        "title": "Load-In Safety Critical",
        "icon": "hard-hat",
        "priority": "critical",
        "items": [
          { "task": "Post site safety rules at all entrances", "priority": "CRITICAL" },
          { "task": "Verify first aid facilities available", "priority": "CRITICAL" },
          { "task": "Confirm structural calculations approved", "priority": "CRITICAL" },
          { "task": "Install fire extinguishers (max 50ft travel)", "priority": "CRITICAL" },
          { "task": "Mark all fire aisles and egress routes", "priority": "CRITICAL" }
        ]
      }
    ],
    "emergency_buttons": [
