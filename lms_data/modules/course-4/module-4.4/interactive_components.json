    {
      "id": "ny_training_selector",
      "type": "training_path_selector",
      "title": "New York Training Certificate Selector",
      "description": "Interactive tool to determine which New York laser operator certificate you need",
      "questions": [
        {
          "id": "q1",
          "question": "What type of lasers will you be operating?",
          "options": [
            {
              "label": "Only low intensity (Class 1, 2, 3R)",
              "result": "Class A Certificate",
              "explanation": "Low intensity lasers require Class A certification."
            },
            {
              "label": "High intensity (Class 3B or 4)",
              "next_question": "q2"
            },
            {
              "label": "Both low and high intensity",
              "result": "Class B Certificate",
              "explanation": "Operating both low and high intensity lasers requires Class B certification."
            }
          ]
        },
        {
          "id": "q2",
          "question": "Will you only operate high intensity lasers, or might you also operate low intensity?",
          "options": [
            {
              "label": "Only high intensity",
              "result": "Class B Certificate",
              "explanation": "Class B covers low and high intensity lasers. Even if you only operate high intensity now, Class B provides full coverage."
            },
            {
              "label": "I might operate both",
              "result": "Class B Certificate",
              "explanation": "Class B is required for any high intensity laser operation, and covers both categories."
            }
          ]
        }
      ],
      "training_providers_map": {
        "class_a": [
          {
