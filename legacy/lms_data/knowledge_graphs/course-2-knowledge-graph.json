    "page_summaries": [
      {"page": 1, "summary": "FDA 2023 final rule amending radiological health regulations, effective February 21, 2023. Removes/reduces annual reports, codifies Laser Notice 41 and 42 policies. Introduces Laser Notice 56 for IEC conformance.", "key_concepts": ["regulatory updates", "reporting exemptions"], "difficulty": "intermediate"},
      {"page": 2, "summary": "Title page identifying HHS Publication FDA 86-8260, Compliance Guide for Laser Products, June 1992.", "key_concepts": ["document identification"], "difficulty": "beginner"},
      {"page": 3, "summary": "Table of contents listing all major sections: Introduction, Classification, Requirements, Recordkeeping, Reporting, Recalls, Variances, and Appendices.", "key_concepts": ["document navigation"], "difficulty": "beginner"},
      {"page": 4, "summary": "Introduction to FFDCA Chapter V, Subchapter C - Electronic Product Radiation Control. Defines laser (180-1,000,000 nm) and manufacturer. Explains guide purpose and limitations.", "key_concepts": ["legal basis", "definitions"], "difficulty": "intermediate"},
      {"page": 5, "summary": "Manufacturer responsibilities: design for compliance, test, certify, maintain records, submit reports, report accidental occurrences and defects, conduct recalls. OEM and export provisions.", "key_concepts": ["manufacturer duties", "OEM requirements"], "difficulty": "intermediate"},
      {"page": 6, "summary": "Classification principles based on highest accessible radiation during operation. Protective housing requirements. Operation vs maintenance vs service definitions.", "key_concepts": ["classification basis", "protective housing"], "difficulty": "advanced"},
      {"page": 7, "summary": "Complete laser class definitions: Class I (inherently safe), Class II (400-710 nm, >0.25 sec), Class IIIa (≤5 mW visible), Class IIIb (5-500 mW, ocular/skin hazard), Class IV (scattered reflection hazard).", "key_concepts": ["class limits", "hazard levels"], "difficulty": "advanced"},
      {"page": 8, "summary": "Measurement methodology: 7mm aperture, 10^-3 or 10^-5 sr acceptance angle, collimating optics ≤5 diopters. Worst-case analysis requirements.", "key_concepts": ["measurement procedures", "radiometric units"], "difficulty": "advanced"},
      {"page": 9, "summary": "Collateral radiation limits (0.5 mR/hr X-ray). Multiple wavelength emission rules. Emission duration range: 1 nanosecond to >10^4 seconds.", "key_concepts": ["collateral radiation", "measurement parameters"], "difficulty": "intermediate"},
      {"page": 10, "summary": "Performance requirements: protective housings must be contiguous, safety interlocks (fail-safe/redundant for Class IIIb/IV), Laser Notice #37 for industrial workstations.", "key_concepts": ["interlock requirements", "protective housing design"], "difficulty": "intermediate"},
      {"page": 11, "summary": "Interlock details: defeatable interlocks require visible/audible indication. Remote interlock connector required for Class IIIb/IV (≤130V rms). Prohibited switch types.", "key_concepts": ["fail-safe design", "remote interlock"], "difficulty": "advanced"},
      {"page": 12, "summary": "Key control, beam attenuator (not power switch), emission indicator with delay, operating controls location, viewing optics (fail-safe), scanning safeguard requirements.", "key_concepts": ["control requirements", "viewing safety"], "difficulty": "advanced"},
      {"page": 13, "summary": "Labeling requirements: CAUTION vs DANGER threshold (2.5 mW/cm²), aperture labels, certification label (21 CFR reference), identification label (manufacturer, date, place).", "key_concepts": ["warning labels", "certification"], "difficulty": "intermediate"},
      {"page": 14, "summary": "Information requirements: user manual content, servicing information, Laser Notice #39 for multi-axis workstations, MPE boundary identification.", "key_concepts": ["documentation requirements"], "difficulty": "intermediate"},
      {"page": 15, "summary": "Specific-purpose products: medical (±20% measurement), surveying/leveling/alignment (5 mW limit), demonstration (Class IIIa limit, variance required for higher), Laser Notice #50 for shows.", "key_concepts": ["medical lasers", "demonstration limits"], "difficulty": "intermediate"},
      {"page": 16, "summary": "Recordkeeping requirements: QC procedures, test results, life testing, safety communications, distribution records. HHS Publication FDA 76-8036 on quality control practices.", "key_concepts": ["recordkeeping", "quality control"], "difficulty": "intermediate"},
      {"page": 17, "summary": "Laser Product Reports required prior to commerce introduction. Product, labeling, compliance method, testing program, life testing, test equipment description.", "key_concepts": ["product reporting"], "difficulty": "intermediate"},
      {"page": 18, "summary": "Class-based reporting: Class I-IIIa require Product and Annual Reports. Class IIIb-IV also require Supplemental Reports. Annual Report due September 1. Laser Notice #41 exemptions.", "key_concepts": ["reporting requirements", "annual reports"], "difficulty": "intermediate"},
      {"page": 19, "summary": "Product recall procedures: notification to CDRH, distributors, purchasers. Corrective Action Plans (CAP). Exemption if no significant injury risk.", "key_concepts": ["recalls", "corrective action"], "difficulty": "advanced"},
      {"page": 20, "summary": "Variance provisions: alternate but equal safety, or product cannot perform function if compliant. Federal agency exemptions (DOD, DOE, NASA, NOAA). Annual reporting exemptions.", "key_concepts": ["variances", "exemptions"], "difficulty": "advanced"},
      {"page": 21, "summary": "Appendix A: Tabulation of requirements by class (I, IIa, II, IIIa, IIIb, IV). Matrix showing performance, labeling, and information requirements with codes R, N/A, S, NP.", "key_concepts": ["requirements matrix"], "difficulty": "intermediate"},
      {"page": 22, "summary": "Appendix A footnotes: interlock variations, medical laser measurement, demonstration variance requirements, effective dates.", "key_concepts": ["requirement clarifications"], "difficulty": "intermediate"},
      {"page": 23, "summary": "Appendix B introduction: variance definition for laser shows, non-transferability, individual performance standard concept, projector vs show manufacturer responsibilities.", "key_concepts": ["laser show variances"], "difficulty": "advanced"},
      {"page": 24, "summary": "Variance amendments for substantial changes. Three reporting methods: general guide, light show guide, notification letter.", "key_concepts": ["variance amendments", "reporting"], "difficulty": "advanced"},
      {"page": 25, "summary": "Reporting guide usage: referencing manufacturer reports, describing compliance with variance conditions, combined reporting approaches.", "key_concepts": ["reporting procedures"], "difficulty": "advanced"},
      {"page": 26, "summary": "Light show report content: touring vs permanent vs special project requirements, installation diagrams, QC procedures, MPE boundaries.", "key_concepts": ["show documentation"], "difficulty": "advanced"},
      {"page": 27, "summary": "Scanning safeguard requirements: audience scanning definition, reaction time specifications, Class I limits for audience areas, variance violation consequences.", "key_concepts": ["scanning safeguards", "audience scanning"], "difficulty": "advanced"},
      {"page": 28, "summary": "Beam stops and overfilling mirrors: mirror ball safeguards, forward scatter considerations, employee-only area exceptions with LSO education.", "key_concepts": ["beam termination", "mirror ball safety"], "difficulty": "advanced"},
      {"page": 29, "summary": "Set-up safety control measures: ANSI Z136.1 compliance, low beam power procedures, personnel clearance protocols.", "key_concepts": ["set-up safety", "ANSI standards"], "difficulty": "intermediate"}
    ]
  }
