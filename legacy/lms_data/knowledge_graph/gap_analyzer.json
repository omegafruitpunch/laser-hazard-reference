  },
  "api_endpoints": {
    "analyze_gaps": {
      "method": "POST",
      "path": "/api/v1/gap-analysis",
      "parameters": {
        "learner_id": "string",
        "certification_target": "clso|cmlso|lso|entertainment_technician",
        "analysis_depth": "basic|detailed|comprehensive"
      },
      "response": {
        "report": "gap_report_object",
        "recommendations": ["recommendation_object"],
        "study_plan": "study_plan_object"
      }
    },
    "get_readiness_score": {
      "method": "GET",
      "path": "/api/v1/readiness/{learner_id}/{certification}",
      "response": {
        "certification": "string",
        "overall_score": "float",
        "topic_scores": "object",
        "ready": "boolean",
        "estimated_preparation_days": "integer"
      }
    },
    "generate_study_plan": {
      "method": "POST",
      "path": "/api/v1/study-plan",
      "parameters": {
        "learner_id": "string",
        "certification_target": "string",
        "timeline_weeks": "integer",
        "weekly_hours": "integer",
        "focus_areas": ["string"]
      },
      "response": {
        "plan_id": "string",
        "weekly_schedule": ["week_object"],
        "milestones": ["milestone_object"],
        "resources": ["resource_object"]
      }
    }
  },
