  "gap_analysis_algorithm": {
    "steps": [
      {
        "step": 1,
        "name": "Collect Learner Data",
        "inputs": ["completed_modules", "assessment_scores", "certification_goal"],
        "outputs": ["learner_profile"]
      },
      {
        "step": 2,
        "name": "Map Completed Concepts",
        "inputs": ["learner_profile", "module_concept_mapping"],
        "outputs": ["mastered_concepts", "partial_concepts"]
      },
      {
        "step": 3,
        "name": "Identify Required Concepts",
        "inputs": ["certification_goal", "certification_requirements"],
        "outputs": ["required_concepts_list"]
      },
      {
        "step": 4,
        "name": "Calculate Concept Gaps",
        "inputs": ["mastered_concepts", "required_concepts_list"],
        "outputs": ["missing_concepts", "gap_percentage"]
      },
      {
        "step": 5,
        "name": "Analyze Prerequisite Chain",
        "inputs": ["missing_concepts", "prerequisite_graph"],
        "outputs": ["prerequisite_gaps", "learning_sequence"]
      },
      {
        "step": 6,
        "name": "Assess Knowledge Depth",
        "inputs": ["mastered_concepts", "assessment_scores"],
        "outputs": ["strength_areas", "weak_areas"]
      },
      {
        "step": 7,
        "name": "Generate Recommendations",
        "inputs": ["gap_percentage", "prerequisite_gaps", "weak_areas"],
        "outputs": ["priority_modules", "study_plan", "timeline"]
      }
    ]
  },
  "remedial_content": {
    "concept_gaps": {
      "fundamentals_missing": {
        "trigger": "missing >30% of beginner concepts",
        "remedial_modules": ["course-1-module-1.1", "course-1-module-1.2"],
        "remedial_resources": ["laser_basics_refresher", "physics_primer"],
        "estimated_hours": 4
      },
      "calculations_weak": {
        "trigger": "NOHD/MPE assessment score <60%",
        "remedial_modules": ["course-1-module-1.3"],
        "remedial_resources": ["math_review", "calculation_worksheet"],
        "estimated_hours": 6
      },
      "regulations_incomplete": {
        "trigger": "missing >40% of regulation concepts",
        "remedial_modules": ["course-2-all", "course-4-all"],
        "remedial_resources": ["regulatory_summary_guide", "compliance_checklist"],
        "estimated_hours": 8
      },
      "bioeffects_incomplete": {
        "trigger": "missing >50% of biology concepts",
        "remedial_modules": ["course-3-all"],
        "remedial_resources": ["eye_anatomy_guide", "damage_mechanisms_summary"],
        "estimated_hours": 6
      }
    },
    "study_plans": {
      "intensive_4_week": {
        "description": "Intensive study for exam preparation",
        "weekly_hours": 20,
        "focus": ["gap_concepts", "practice_exams"],
        "recommended_for": ["imminent_exam_date", "strong_background"]
      },
      "standard_12_week": {
        "description": "Standard preparation timeline",
        "weekly_hours": 8,
        "focus": ["complete_coverage", "steady_progress"],
        "recommended_for": ["most_learners", "working_professionals"]
      },
      "extended_24_week": {
        "description": "Extended timeline for thorough understanding",
        "weekly_hours": 4,
        "focus": ["deep_learning", "practical_application"],
        "recommended_for": ["beginners", "limited_time"]
      }
    }
  },
  "assessment_integration": {
    "concept_mastery_criteria": {
      "assessment_score_threshold": 80,
      "practical_demonstration": true,
      "time_since_completion_max_days": 90
    },
    "weakness_indicators": [
      {
        "indicator": "quiz_failure",
        "threshold": "<70% on first attempt",
        "action": "flag_concept_for_review"
      },
      {
        "indicator": "multiple_attempts",
        "threshold": ">3 attempts to pass",
        "action": "suggest_prerequisite_review"
      },
      {
        "indicator": "time_exceeded",
        "threshold": ">2x estimated time",
        "action": "offer_simplified_explanation"
      },
      {
        "indicator": "related_failures",
        "threshold": "failures in >3 related concepts",
        "action": "recommend_foundational_review"
      }
    ]
  },
