              "Purpose and scope of the procedure",
              "Personnel authorized to perform the work",
              "Required training and qualifications",
              "Step-by-step instructions",
              "Required PPE and controls",
              "Emergency procedures",
              "Date of creation and review schedule"
            ],
            "laser_specific_sops": [
              "Laser startup and shutdown procedures",
              "Alignment procedures",
              "Maintenance procedures",
              "Emergency response procedures",
              "Service and repair procedures"
            ]
          },
          {
            "name": "Signage and Labeling",
            "requirements": {
              "Class_2": ["CAUTION - Laser Radiation"],
              "Class_3R": ["CAUTION - Laser Radiation"],
