              {"type": "Aperture labels", "text": "Laser Aperture - Avoid Exposure"},
              {"type": "Area signs", "text": "Controlled Area - Authorized Personnel Only"},
              {"type": "Eyewear reminder", "text": "Laser Safety Eyewear Required in This Area"}
            ]
          },
          {
            "name": "Training and Authorization",
            "requirements": [
              "Initial safety training before first work assignment",
              "Refresher training annually or after incidents",
              "Written authorization before independent work",
              "Documentation of all training",
              "Competency verification"
            ],
            "training_topics": [
              "Laser fundamentals and bioeffects",
              "Classification and hazard categories",
              "Control measures and their use",
              "MPE and exposure limits",
              "Emergency procedures",
              "Incident reporting"
            ]
          }
        ]
      }
    },
