    "questions": [
      {
        "id": "q1",
        "type": "multiple_choice",
        "question": "Who has primary jurisdiction over laser PRODUCT safety and compliance?",
        "options": [
          "OSHA",
          "FDA/CDRH",
          "State Health Departments",
          "EPA"
        ],
        "correct_answer": 1,
        "cfr_reference": "21 CFR 1002-1005"
      },
      {
        "id": "q2",
        "type": "multiple_choice",
        "question": "When must a radiation defect notification be submitted?",
        "options": [
          "Within 30 days of discovery",
          "Immediately upon discovery",
          "In the next Annual Report",
          "Within 24 hours"
        ],
        "correct_answer": 1,
        "cfr_reference": "21 CFR 1003.10"
      },
      {
        "id": "q3",
        "type": "multiple_select",
        "question": "Which agencies might have jurisdiction over a workplace laser injury? (Select all that apply)",
        "options": [
          "FDA/CDRH",
          "OSHA",
          "State Radiation Control",
          "State Health Department"
        ],
        "correct_answers": [0, 1, 2],
        "cfr_reference": "Multiple"
      },
      {
        "id": "q4",
        "type": "true_false",
        "question": "Defects must be reported to FDA before attempting repair or correction.",
        "correct_answer": true,
        "cfr_reference": "21 CFR 1003.10(b)"
      }
    ]
