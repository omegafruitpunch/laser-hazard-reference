  "sections": [
    {
      "id": "regulatory_models_overview",
      "title": "Regulatory Models Overview",
      "type": "comparison_overview",
      "content": {
        "summary": "The four states in this module represent a spectrum of regulatory approaches. Nevada and Washington follow notification-based models with minimal oversight. New York implements comprehensive regulations with mandatory training certification. Texas combines comprehensive regulation with active industry engagement through ILDA.",
        "regulatory_tiers": {
          "notification_only": {
            "states": ["Nevada", "Washington"],
            "characteristics": [
              "Advance notification required",
              "No routine inspections",
              "Minimal registration requirements",
              "Focus on documentation over enforcement"
            ]
          },
          "comprehensive_regulation": {
            "states": ["New York", "Texas"],
            "characteristics": [
              "Mandatory registration",
              "Routine inspections conducted",
              "Specific training requirements",
              "Active enforcement mechanisms"
            ]
          }
        },
        "visual_hierarchy": {
          "least_restrictive": "Nevada, Washington (notification only)",
          "moderate": "Illinois, Massachusetts (comprehensive from previous module)",
          "most_restrictive": "New York, Texas (comprehensive + inspections/training)"
        }
      }
    },
