  "content_structure": {
    "warmup": {
      "title": "Crowd Dynamics",
      "duration": 5,
      "icon": "users",
      "activities": [
        "Hillsborough case study",
        "Density fundamentals",
        "Behavior factors"
      ]
    },
    "core": {
      "title": "Density Management",
      "duration": 16,
      "icon": "activity",
      "activities": [
        "Interactive density calculator",
        "Emergency egress planner",
        "Dangerous condition recognition"
      ]
    },
    "practice": {
      "title": "Response Scenarios",
      "duration": 7,
      "icon": "alert-triangle",
      "activities": [
        "Surge detection scenario",
        "Barrier emergency response",
        "Evacuation decision making"
      ]
    },
    "challenge": {
      "title": "Crowd Safety Expert",
      "duration": 2,
      "icon": "award",
      "activities": [
        "Knowledge verification",
        "Competency badge award"
      ]
    }
  },
  "emergency_elements": {
    "quick_access_checklists": [
      {
        "id": "crowd-monitoring",
        "title": "CROWD MONITORING CHECKLIST",
        "icon": "eye",
        "priority": "critical",
        "items": [
          { "task": "Monitor crowd density continuously", "priority": "CRITICAL", "threshold": "STOP ENTRY at 1 per 5 sq ft" },
          { "task": "Watch for crowd waves and movement patterns", "priority": "CRITICAL" },
          { "task": "Check barrier stability every 15 min", "priority": "HIGH" },
          { "task": "Verify emergency routes remain clear", "priority": "CRITICAL", "frequency": "Every 30 min" },
          { "task": "Maintain communication with all stewards", "priority": "CRITICAL" }
        ]
      },
      {
        "id": "surge-response",
        "title": "CROWD SURGE RESPONSE",
        "icon": "alert-octagon",
        "priority": "critical",
        "color": "danger",
        "items": [
          { "task": "STOP THE EVENT immediately", "priority": "CRITICAL", "auto_trigger": "density > 1 per 5 sq ft" },
          { "task": "Open additional egress routes", "priority": "CRITICAL" },
          { "task": "PA announcement requesting calm", "priority": "HIGH" },
          { "task": "Deploy all available crowd managers", "priority": "CRITICAL" },
          { "task": "Medical teams to standby", "priority": "HIGH" }
        ]
      }
    ],
    "emergency_buttons": [
      {
        "id": "stop-event",
        "label": "STOP EVENT",
        "color": "danger",
        "icon": "octagon-x",
        "action": "immediate_show_stop",
        "confirmation_required": true,
        "style": "pulsing_critical",
        "conditions": ["crowd_surge_detected", "barrier_failure", "medical_emergency"]
      },
      {
        "id": "density-alert",
        "label": "DENSITY CRITICAL",
        "color": "crowd_critical",
        "icon": "users",
        "action": "density_warning_protocol",
        "auto_trigger": "density > 1 per 5 sq ft"
      }
    ],
    "warning_signs": [
      {
        "sign": "Crowd Surge",
        "indicators": ["Waves of movement", "People losing balance", "Compression at barriers", "Cries of distress"],
        "actions": ["Stop event", "Open egress", "PA announcement", "Deploy managers"]
      },
      {
        "sign": "Barrier Failure",
        "indicators": ["Visible barrier movement", "Barriers leaning", "Gaps appearing", "Noise from connections"],
        "actions": ["Clear area", "Stop event", "Reinforce barriers", "Redirect flow"]
      },
      {
        "sign": "Crowd Collapse",
        "indicators": ["People falling", "Cries for help", "Visible distress", "Chaotic waves"],
        "actions": ["Stop event immediately", "Emergency extraction", "Call medical", "Clear space"]
      }
    ]
  },
