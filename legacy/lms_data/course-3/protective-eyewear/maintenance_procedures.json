  "cleaning_procedures": {
    "daily_cleaning": {
      "frequency": "After each use",
      "supplies": [
        "Clean, lint-free microfiber cloth",
        "Mild soap and water solution",
        "Lens cleaning solution (alcohol-free recommended)"
      ],
      "procedure": [
        "Rinse lenses under lukewarm water to remove dust/debris",
        "Apply small amount of mild soap or lens cleaner",
        "Gently rub both sides with clean fingers or soft cloth",
        "Rinse thoroughly with clean water",
        "Dry with clean microfiber cloth (pat, don't rub)",
        "Inspect for remaining spots or streaks"
      ],
      "prohibited": [
        "Paper towels or tissues (can scratch)",
        "Ammonia-based cleaners (can damage coatings)",
        "Abrasive cleaners",
        "Hot water (can damage coatings)",
        "Dry wiping (grit can scratch)"
      ]
    },
    "deep_cleaning": {
      "frequency": "Weekly or as needed",
      "procedure": [
        "Remove any detachable parts (side shields, etc.)",
        "Clean all surfaces with mild soap solution",
        "Clean nose bridge and temple tips thoroughly",
        "Clean ventilation holes if present",
        "Dry completely before storage"
      ]
    }
  },
