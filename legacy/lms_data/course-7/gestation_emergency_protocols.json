  "major_incident_planning": {
    "title": "Major Incident Planning",
    "definitions": {
      "minor_incident": {
        "description": "Can be managed through routine arrangements",
        "examples": [
          "Low-level crime",
          "Lost children",
          "Minor injuries",
          "Small medical emergencies"
        ]
      },
      "major_incident": {
        "description": "Requires special arrangements and resources",
        "characteristics": [
          "Large number of casualties",
          "Direct or indirect involvement of large numbers",
          "Large scale media interest",
          "Combined resources of multiple emergency services",
          "Threat of death or serious injury to many"
        ]
      }
    },
